MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxxx-shard-0&authSource=admin&appName=rescue-bird
MONGODB_DB=rescue-bird
JWT_SECRET=replace_with_long_random_secret
OTP_SECRET=replace_with_different_long_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Brevo SMTP (same style as PersonalBank)
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587
BREVO_USER=your_brevo_smtp_user
BREVO_PASS=your_brevo_smtp_password
EMAIL_SENDER_EMAIL=no-reply@example.com

# Cloudinary (voice-note upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=rescue-bird/voice-notes
